# ============================================================
# CRM DERMOTEC — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://wtbrdxijvtelluwfmgsf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (emails transactionnels) ---
RESEND_API_KEY=re_...
EMAIL_FROM=Dermotec Formation <contact@dermotec.fr>
ADMIN_EMAIL=dermotec.fr@gmail.com

# --- IA (au moins 1 requis pour les fonctions IA) ---
# DeepSeek (recommandé — 10-20x moins cher que GPT-4o)
DEEPSEEK_API_KEY=sk-...
# OU Mistral (RGPD-friendly, serveurs EU)
MISTRAL_API_KEY=...
# OU OpenAI (fallback)
OPENAI_API_KEY=sk-...

# --- Recherche prospect (optionnel, enrichit la recherche IA) ---
# Perplexity Sonar (recommandé — $5/1000 queries)
PERPLEXITY_API_KEY=pplx-...
# OU Tavily (alternative — gratuit 1000 req/mois)
TAVILY_API_KEY=tvly-...

# --- Twilio (SMS + WhatsApp — optionnel) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...
TWILIO_WHATSAPP_NUMBER=whatsapp:+33...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.dermotec.fr

# --- Cron (sécurité des endpoints cron) ---
CRON_SECRET=your_random_secret_here

# --- Optionnel (futur) ---
# GOOGLE_CALENDAR_API_KEY=
# SENTRY_DSN=
# POSTHOG_KEY=
