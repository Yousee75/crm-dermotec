'use client'

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query'
import { createClient } from '@/lib/supabase-client'

export function useCommissions(filters?: {
  commercial_id?: string
  mois?: string
  statut?: string
}) {
  const supabase = createClient()

  return useQuery({
    queryKey: ['commissions', filters],
    queryFn: async () => {
      let query = supabase
        .from('commissions')
        .select('*')
        .order('date_conversion', { ascending: false })

      if (filters?.commercial_id) query = query.eq('commercial_id', filters.commercial_id)
      if (filters?.mois) query = query.eq('mois_reference', filters.mois)
      if (filters?.statut) query = query.eq('statut', filters.statut)

      const { data, error } = await query
      if (error) throw error
      return data || []
    },
  })
}

export function useCommissionsResume(mois?: string) {
  const supabase = createClient()

  return useQuery({
    queryKey: ['commissions-resume', mois],
    queryFn: async () => {
      let query = supabase
        .from('v_commissions_resume')
        .select('*')
        .order('mois_reference', { ascending: false })

      if (mois) query = query.eq('mois_reference', mois)

      const { data, error } = await query
      if (error) throw error
      return data || []
    },
  })
}

export function useValiderCommission() {
  const supabase = createClient()
  const queryClient = useQueryClient()

  return useMutation({
    mutationFn: async ({ id, action }: { id: string; action: 'VALIDEE' | 'ANNULEE' }) => {
      const updates: Record<string, unknown> = { statut: action }
      if (action === 'VALIDEE') updates.date_validation = new Date().toISOString()
      if (action === 'ANNULEE') updates.notes = 'Annulee par le manager'

      const { error } = await supabase.from('commissions').update(updates).eq('id', id)
      if (error) throw error
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['commissions'] })
      queryClient.invalidateQueries({ queryKey: ['commissions-resume'] })
    },
  })
}

export function useMarquerPayee() {
  const supabase = createClient()
  const queryClient = useQueryClient()

  return useMutation({
    mutationFn: async (ids: string[]) => {
      const { error } = await supabase
        .from('commissions')
        .update({
          statut: 'PAYEE',
          date_paiement: new Date().toISOString(),
        })
        .in('id', ids)
      if (error) throw error
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['commissions'] })
      queryClient.invalidateQueries({ queryKey: ['commissions-resume'] })
    },
  })
}
